.post-body
  mjx-container[display='true']
    box-sizing: border-box
    max-width: 100%
    min-width: 0 !important
    overflow-x: auto
    overflow-y: hidden
    padding-bottom: .15em
    width: 100%

    > svg
      max-width: none

body > canvas[id^='c_n']
  max-width: 100% !important
  pointer-events: none !important
  width: 100% !important
